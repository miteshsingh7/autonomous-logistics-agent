# ---------------------------------------------------------------------------
# Model access
# ---------------------------------------------------------------------------
# We route BOTH the closed and open model through a single OpenAI-compatible
# endpoint (the Vercel AI Gateway) so switching models is a one-line change.
#
# Get a key at https://vercel.com/ai-gateway  (or point BASE_URL at any
# OpenAI-compatible gateway such as OpenRouter / LiteLLM / Together).
AI_GATEWAY_API_KEY=your_key_here
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Model identifiers (gateway "provider/model" strings).
# These are the two systems under comparison.
CLOSED_MODEL=anthropic/claude-sonnet-4
OPEN_MODEL=meta/llama-3.3-70b-instruct

# ---------------------------------------------------------------------------
# Run mode
# ---------------------------------------------------------------------------
# Set to "1" to run fully offline with a deterministic mock model.
# Useful for reviewing the harness without spending tokens.
MOCK_MODE=0
